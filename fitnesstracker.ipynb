def fitness_tracker():
    exercises = []
    daily_goal = float(input("Enter your daily calorie burn goal: "))

    while True:
        print("\nEnter exercise details:")
        name = input("Exercise name: ")
        duration = float(input("Duration (in minutes): "))
        calories_per_minute = float(input("Calories burned per minute: "))
        total_calories = duration * calories_per_minute
        exercises.append((name, duration, total_calories))
        another = input("Add another exercise? (yes/no): ").strip().lower()
        if another != 'yes':
            break

    total_calories_burned = sum(exercise[2] for exercise in exercises)

    print("\n--- Fitness Tracker Summary ---")
    print("Exercises logged:")
    for exercise in exercises:
        print(f"- {exercise[0]}: {exercise[1]} minutes, {exercise[2]:.2f} calories burned")

    print(f"\nTotal calories burned: {total_calories_burned:.2f}")
    if total_calories_burned < daily_goal:
        print("Keep going! You're below your daily goal. Stay motivated!")
    else:
        print("Congratulations! You've surpassed your daily goal!")

fitness_tracker()
